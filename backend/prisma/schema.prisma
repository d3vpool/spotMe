generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String
  password  String
  createdAt DateTime @default(now())
}

model event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  createdBy   Int
  shareToken  String
  createdAt   DateTime @default(now())
  images      image[]
}

model image {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  eventId   Int
  createdAt DateTime @default(now())
  event     event    @relation(fields: [eventId], references: [id])
  faceEmbeddings faceEmbedding[]
}

model faceEmbedding {
  id Int @id @default(autoincrement())
  imageId Int
  vector Unsupported("vector(128)")
  image image @relation(fields: [imageId], references: [id])
  boundingBox Json?
  createdAt DateTime @default(now())
}
